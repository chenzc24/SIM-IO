{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pin Classification Output",
  "description": "Schema for LLM-generated pin classification results",
  "type": "object",
  "required": ["lib", "cell", "vdd_value", "pins"],
  "properties": {
    "lib": {
      "type": "string",
      "description": "Virtuoso library name"
    },
    "cell": {
      "type": "string",
      "description": "Primary cell name"
    },
    "vdd_value": {
      "type": "number",
      "description": "Supply voltage in volts"
    },
    "llm_model": {
      "type": "string",
      "description": "LLM model that generated this classification"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp"
    },
    "pins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "pin_type", "confidence", "reason"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Pin name (must match pin_info.json)"
          },
          "pin_type": {
            "type": "string",
            "enum": [
              "power",
              "ground",
              "digital_input",
              "digital_output",
              "digital_bidirectional",
              "analog_input",
              "analog_output",
              "analog_bidirectional",
              "clock",
              "reset",
              "reference",
              "no_connect"
            ],
            "description": "Classified pin type"
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "LLM self-assessed confidence (0.0-1.0)"
          },
          "reason": {
            "type": "string",
            "description": "Why this classification was chosen"
          },
          "stimulus": {
            "type": ["string", "null"],
            "description": "Override: specific stimulus cell name (e.g. 'vpulse', 'vpwl')"
          },
          "load": {
            "type": ["string", "null"],
            "description": "Override: specific load cell name (e.g. 'cap', 'res')"
          }
        }
      }
    }
  }
}
