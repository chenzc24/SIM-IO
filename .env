# ──────────────────────────────────────────────────────────────────────────
# SIM-IO Skill Configuration
#
# This file is loaded automatically by site_config.py.
# It is independent from the project-root .env (bridge config).
#
# Fields you may need to change are marked with:  # ← CHANGE if needed
# ──────────────────────────────────────────────────────────────────────────

# ── Git Bash path conversion guard ────────────────────────────────────────
# Prevents Git Bash from converting POSIX paths (e.g. /home/process/...)
# to Windows paths (C:/Program Files/Git/home/...) when exporting env vars
# to native Windows executables like python.exe.
MSYS_NO_PATHCONV=1
MSYS2_ARG_CONV_EXCL=*

# ── Netlist Export (si batch) ──────────────────────────────────────
# Absolute path to your cds.lib on the EDA server (Linux path).
# Must include analogLib/basic definitions or chain to IC618's cds.lib.
# ← CHANGE path to match your cds.lib location
SIM_CDS_LIB=/home/chenzc_intern25/TSMC28/llm_IO/cds.lib

# Cadence IC installation root on the EDA server.
# ← CHANGE path to match your Cadence installation
SIM_IC_ROOT=/home/cadence/ic618/IC618Hotfix4

# MMSIM (Spectre) installation root on the EDA server.
# Spectre is a separate product from Virtuoso (IC618).
# If unset, the pipeline will attempt to auto-discover from Virtuoso's PATH.
# ← CHANGE if spectre is installed elsewhere
SIM_MMSIM_ROOT=/home/cadence/spectre/SPECTRE211Hotfix

# License env vars (optional — auto-discovered from Virtuoso if unset)
# If set, these take priority over SKILL auto-discovery.
SIM_LM_LICENSE_FILE=5280@thu-han
SIM_CDS_LIC_FILE=5280@thu-han

# ── Simulation (Spectre) ──────────────────────────────────────────
# PDK model include path on the EDA server (Spectre format).
# Used by build_sim_deck() to add `include "..." section=TT` to the deck.
# ← CHANGE path to match your PDK model location
# SIM_PDK_SPECTRE_INCLUDE=/path/to/PDK/toplevel.scs

# PDK IO pad model include path on the EDA server (SPICE format).
# TSMC28 IO pad cells (tphn28hpcpgv18) need their subcircuit definitions
# included separately from the core model file.  This is a SPICE-format
# file — the deck builder automatically wraps it with simulator lang=spice.
SIM_PDK_IO_SPECTRE_INCLUDE=/home/process/tsmc28n/IO/tphn28hpcpgv18_170a/0971001_20180621/tphn28hpcpgv18_110a_spi/TSMCHOME/digital/Back_End/spice/tphn28hpcpgv18_110a/tphn28hpcpgv18.spi

# PDK core model include path (Spectre format) for TSMC28.
# This is the primary technology model file with sections like
# pre_simu, ttmacro_mos_moscap, tt_res_bip_dio_disres, etc.
# The LLM should prefer this over HSPICE .l files for Spectre simulation.
# ← CHANGE path to match your PDK core model location
SIM_PDK_CORE_SPECTRE_INCLUDE=/home/process/tsmc28n/PDK_mmWave/iPDK_CRN28HPC+ULL_v1.8_2p2a_20190531/models/spectre/crn28ull_1d8_elk_v1d8_2p2_shrink0d9_embedded_usage.scs

# Comma-separated list of model sections to include from the core model file.
# These sections are used for TT corner simulation.
SIM_PDK_CORE_SPECTRE_SECTIONS=pre_simu,ttmacro_mos_moscap,tt_res_bip_dio_disres,tt_mom,tt_ind_jvar,tt_r_metal,noise_worst
